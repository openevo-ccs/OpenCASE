<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - OpenCASE Admin</title>
  <link rel="stylesheet" href="/static/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sky: '#55B1E8',
            blue: '#0000FF',
            navy: '#000072',
            gold: '#FFBF00',
            amber: '#FF941F',
            violet: '#6129FF',
            plum: '#662F90',
            charcoal: '#2E2F2F',
            gray: '#919496',
            silver: '#EBEBEB'
          },
          fontFamily: {
            sans: ['Nunito', 'sans-serif'],
            header: ['Barlow', 'sans-serif']
          }
        }
      }
    }
  </script>
</head>
<body class="bg-white">
  <nav class="bg-white border-b border-gray-200">
    <div class="container mx-auto px-6 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded bg-plum flex items-center justify-center">
            <span class="text-white font-bold text-sm">OC</span>
          </div>
          <h1 class="text-lg font-header font-semibold text-gray-900">OpenCASE Admin</h1>
        </div>
        <div class="flex items-center gap-4">
          <a href="/admin/tenants/demo/frameworks" class="text-gray-600 hover:text-gray-900 transition-colors text-sm font-medium">Frameworks</a>
          <form method="POST" action="/admin/logout" class="inline">
            <button type="submit" class="text-gray-600 hover:text-gray-900 transition-colors text-sm font-medium">Logout</button>
          </form>
        </div>
      </div>
    </div>
  </nav>

  <main class="container mx-auto px-6 py-10 max-w-7xl">
    {{{body}}}
  </main>
</body>
</html>

