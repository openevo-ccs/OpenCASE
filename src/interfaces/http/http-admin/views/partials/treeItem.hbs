<div class="tree-item-card bg-white border border-gray-200 rounded-md hover:bg-gray-50 transition-colors py-3 px-4 mb-1">
  <div class="flex items-start justify-between group">
    <div class="flex-1 min-w-0">
      <div class="flex items-start gap-3">
        {{#if item.children}}
          <button 
            onclick="toggleChildren(this)"
            class="toggle-button flex-shrink-0 w-5 h-5 rounded border border-gray-300 bg-white hover:bg-gray-50 flex items-center justify-center text-gray-600 transition-colors mt-0.5"
            aria-label="Toggle children"
          >
            <svg class="toggle-icon w-3 h-3 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
        {{else}}
          <div class="w-5"></div>
        {{/if}}
        <div class="flex-1">
          <div class="flex items-start gap-2 flex-wrap">
            {{#if item.humanCodingScheme}}
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-mono text-gray-600 bg-gray-100">{{item.humanCodingScheme}}</span>
            {{/if}}
            <h3 class="font-header font-medium text-gray-900 text-sm leading-snug">{{item.fullStatement}}</h3>
          </div>
          {{#if item.abbreviatedStatement}}
            <p class="text-xs text-gray-600 mt-1 leading-relaxed">{{item.abbreviatedStatement}}</p>
          {{/if}}
          {{#if item.notes}}
            <p class="text-xs text-gray-500 mt-1 leading-relaxed">{{item.notes}}</p>
          {{/if}}
        </div>
      </div>
    </div>
    <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity ml-4">
      <a 
        href="/admin/tenants/{{tenantId}}/frameworks/{{frameworkId}}/items/{{item.identifier}}/edit" 
        class="inline-flex items-center gap-1 text-plum hover:text-plum-700 text-xs px-2 py-1 rounded hover:bg-plum-50 transition-colors font-medium"
      >
        Edit
      </a>
      <a 
        href="/admin/tenants/{{tenantId}}/frameworks/{{frameworkId}}/items/{{item.identifier}}/add-child" 
        class="inline-flex items-center gap-1 text-plum hover:text-plum-700 text-xs px-2 py-1 rounded hover:bg-plum-50 transition-colors font-medium"
      >
        Add Child
      </a>
      <form 
        method="POST" 
        action="/admin/tenants/{{tenantId}}/frameworks/{{frameworkId}}/items/{{item.identifier}}" 
        class="inline"
        onsubmit="return confirm('Delete this item?')"
      >
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" class="inline-flex items-center gap-1 text-red-600 hover:text-red-700 text-xs px-2 py-1 rounded hover:bg-red-50 transition-colors font-medium">
          Delete
        </button>
      </form>
    </div>
  </div>
  {{#if item.children}}
    <div class="tree-children ml-8 mt-2 space-y-1">
      {{#each item.children}}
        {{> treeItem item=this tenantId=../tenantId frameworkId=../frameworkId level=../nextLevel}}
      {{/each}}
    </div>
  {{/if}}
</div>
