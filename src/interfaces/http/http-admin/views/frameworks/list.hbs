<div class="mb-6 flex items-center justify-between">
  <h2 class="text-xl font-header font-semibold text-gray-900">Frameworks</h2>
  <a href="/admin/tenants/{{tenantId}}/frameworks/new" 
     class="inline-flex items-center gap-1.5 bg-amber text-white px-4 py-2 rounded-md hover:bg-opacity-90 text-sm font-medium transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
    </svg>
    Create Framework
  </a>
</div>

{{#if frameworks}}
  <div class="space-y-1">
    {{#each frameworks}}
      <div class="bg-white border border-gray-200 rounded-md hover:bg-gray-50 transition-colors py-3 px-4">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <h3 class="text-sm font-header font-medium text-gray-900 mb-0.5">{{title}}</h3>
            {{#if description}}
              <p class="text-xs text-gray-600 mb-2">{{description}}</p>
            {{/if}}
            <div class="flex items-center gap-3 text-xs text-gray-500">
              <span class="font-mono">ID: {{sourcedId}}</span>
              {{#if lastChangeDateTime}}
                <span>Updated: {{lastChangeDateTime}}</span>
              {{/if}}
            </div>
          </div>
          <div class="flex items-center gap-2 ml-4">
            <a href="/admin/tenants/{{../tenantId}}/frameworks/{{sourcedId}}" 
               class="inline-flex items-center gap-1 text-plum hover:text-plum-700 px-2 py-1 rounded hover:bg-plum-50 transition-colors text-xs font-medium">
              View
            </a>
            <form method="POST" action="/admin/tenants/{{../tenantId}}/frameworks/{{sourcedId}}" 
                  class="inline" onsubmit="return confirm('Delete this framework?')">
              <input type="hidden" name="_method" value="DELETE">
              <button type="submit" class="inline-flex items-center gap-1 text-red-600 hover:text-red-700 px-2 py-1 rounded hover:bg-red-50 transition-colors text-xs font-medium">
                Delete
              </button>
            </form>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <div class="bg-white border border-gray-200 rounded-md py-8 text-center">
    <p class="text-gray-500 mb-4 text-sm">No frameworks found.</p>
    <a href="/admin/tenants/{{tenantId}}/frameworks/new" 
       class="inline-flex items-center gap-1.5 bg-amber text-white px-4 py-2 rounded-md hover:bg-opacity-90 text-sm font-medium transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Create Your First Framework
    </a>
  </div>
{{/if}}

