<div class="mb-6">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h2 class="text-2xl font-header font-semibold text-gray-900 mb-1">{{framework.title}}</h2>
      {{#if framework.description}}
        <p class="text-gray-600 text-sm">{{framework.description}}</p>
      {{/if}}
    </div>
    <div class="flex items-center gap-2">
      <a 
        href="/admin/tenants/{{tenantId}}/frameworks/{{framework.identifier}}/items/new" 
        class="inline-flex items-center gap-1.5 bg-amber text-white px-4 py-2 rounded-md hover:bg-opacity-90 text-sm font-medium transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Add Item
      </a>
      <a 
        href="/admin/tenants/{{tenantId}}/frameworks" 
        class="inline-flex items-center gap-1.5 bg-white text-gray-700 px-4 py-2 rounded-md border border-gray-300 hover:bg-gray-50 text-sm font-medium transition-colors"
      >
        Back
      </a>
    </div>
  </div>
  <div class="flex items-center gap-4 text-xs text-gray-500">
    <span>{{itemCount}} items</span>
    <span>{{associationCount}} associations</span>
  </div>
</div>

{{#if error}}
  <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md mb-4">
    <p class="font-semibold">Error:</p>
    <p>{{error}}</p>
  </div>
{{/if}}

<div class="bg-white">
  <div class="py-4">
    {{#if tree}}
      <div class="space-y-2">
        {{#each tree}}
          {{> treeItem item=this tenantId=../tenantId frameworkId=../framework.identifier level=0}}
        {{/each}}
      </div>
    {{else}}
      <div class="text-center py-12">
        <p class="text-gray-500 mb-4 text-sm">This framework has no items yet.</p>
        <a 
          href="/admin/tenants/{{tenantId}}/frameworks/{{framework.identifier}}/items/new" 
          class="inline-flex items-center gap-1.5 bg-amber text-white px-4 py-2 rounded-md hover:bg-opacity-90 text-sm font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Add Your First Item
        </a>
      </div>
    {{/if}}
  </div>
</div>

<style>
  .tree-children.hidden {
    display: none;
  }
  .tree-item-card[data-collapsed="true"] .toggle-icon {
    transform: rotate(-90deg);
  }
</style>
<script>
  function toggleChildren(element) {
    const card = element.closest('.tree-item-card');
    const childrenContainer = card.querySelector('.tree-children');
    const icon = element.querySelector('.toggle-icon');
    if (childrenContainer) {
      const isHidden = childrenContainer.classList.contains('hidden');
      childrenContainer.classList.toggle('hidden');
      if (isHidden) {
        card.removeAttribute('data-collapsed');
      } else {
        card.setAttribute('data-collapsed', 'true');
      }
    }
  }
</script>
