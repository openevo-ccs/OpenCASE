<div class="mb-6">
  <h2 class="text-xl font-header font-semibold text-gray-900 mb-1">Create New Framework</h2>
  <p class="text-gray-600 text-sm">Fill in the basic information to create an empty framework. You can add items and associations later.</p>
</div>

{{#if error}}
  <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md mb-4">
    <p class="font-semibold">Error:</p>
    <p>{{error}}</p>
  </div>
{{/if}}

<div class="bg-white border border-gray-200 rounded-md p-6">
  <form method="POST" action="/admin/tenants/{{tenantId}}/frameworks" class="space-y-6" enctype="application/x-www-form-urlencoded">
    
    <div class="grid grid-cols-1 gap-6">
      <!-- Framework Title -->
      <div>
        <label for="title" class="block text-sm font-medium text-gray-900 mb-2">
          Framework Title <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          id="title"
          name="title"
          required
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="e.g., Common Core State Standards for Mathematics"
        />
        <p class="mt-1 text-sm text-gray-600">The name of your learning standards framework</p>
      </div>

      <!-- Framework ID -->
      <div>
        <label for="identifier" class="block text-sm font-medium text-gray-700 mb-2">
          Framework ID <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          id="identifier"
          name="identifier"
          required
          pattern="[a-zA-Z0-9_-]+"
          class="w-full border border-gray-300 rounded-md px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          placeholder="e.g., ccss-math-2024"
        />
        <p class="mt-1 text-sm text-gray-500">A unique identifier (letters, numbers, hyphens, and underscores only)</p>
      </div>

      <!-- Creator -->
      <div>
        <label for="creator" class="block text-sm font-medium text-gray-700 mb-2">
          Creator/Author <span class="text-red-600">*</span>
        </label>
        <input
          type="text"
          id="creator"
          name="creator"
          required
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="e.g., State Department of Education"
        />
        <p class="mt-1 text-sm text-gray-500">The organization or person who created this framework</p>
      </div>

      <!-- Description -->
      <div>
        <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
          Description
        </label>
        <textarea
          id="description"
          name="description"
          rows="3"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="A brief description of what this framework covers..."
        ></textarea>
        <p class="mt-1 text-sm text-gray-500">Optional: Describe the purpose and scope of this framework</p>
      </div>

      <!-- Subject -->
      <div>
        <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">
          Subject Area
        </label>
        <input
          type="text"
          id="subject"
          name="subject"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="e.g., Mathematics, English Language Arts, Science"
        />
        <p class="mt-1 text-sm text-gray-500">Optional: The subject or discipline this framework covers</p>
      </div>

      <!-- Language -->
      <div>
        <label for="language" class="block text-sm font-medium text-gray-700 mb-2">
          Language
        </label>
        <select
          id="language"
          name="language"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
        >
          <option value="en">English</option>
          <option value="es">Spanish</option>
          <option value="fr">French</option>
          <option value="de">German</option>
          <option value="zh">Chinese</option>
          <option value="">Other</option>
        </select>
        <p class="mt-1 text-sm text-gray-500">The primary language of the framework content</p>
      </div>

      <!-- Publisher -->
      <div>
        <label for="publisher" class="block text-sm font-medium text-gray-700 mb-2">
          Publisher
        </label>
        <input
          type="text"
          id="publisher"
          name="publisher"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="e.g., State Board of Education"
        />
        <p class="mt-1 text-gray-500 text-sm">Optional: The organization that published this framework</p>
      </div>
    </div>

    <div class="flex items-center gap-2 pt-4 border-t border-gray-200">
      <button
        type="submit"
        class="inline-flex items-center gap-1.5 bg-amber text-white px-4 py-2 rounded-md hover:bg-opacity-90 focus:outline-none focus:ring-2 focus:ring-amber focus:ring-offset-2 text-sm font-medium transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Create Framework
      </button>
      <a
        href="/admin/tenants/{{tenantId}}/frameworks"
        class="inline-flex items-center gap-1.5 bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300 focus:ring-offset-2 text-sm font-medium transition-colors"
      >
        Cancel
      </a>
    </div>
  </form>
</div>
