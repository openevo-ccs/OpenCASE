<div class="mb-6">
  <h2 class="text-xl font-header font-semibold text-gray-900 mb-1">Edit Item</h2>
  <p class="text-gray-600 text-sm">Framework: <span class="font-medium">{{framework.title}}</span></p>
</div>

{{#if error}}
  <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md mb-4">
    <p class="font-semibold">Error:</p>
    <p>{{error}}</p>
  </div>
{{/if}}

<div class="bg-white border border-gray-200 rounded-md p-6">
  <form method="POST" action="/admin/tenants/{{tenantId}}/frameworks/{{frameworkId}}/items/{{item.identifier}}" class="space-y-6" enctype="application/x-www-form-urlencoded">
    <input type="hidden" name="_method" value="PUT" />
    
    <div class="grid grid-cols-1 gap-6">
      <!-- Item ID (read-only) -->
      <div>
        <label for="identifier" class="block text-sm font-medium text-gray-900 mb-2">
          Item ID
        </label>
        <input
          type="text"
          id="identifier"
          name="identifier"
          value="{{item.identifier}}"
          disabled
          class="w-full border border-gray-300 rounded-md px-3 py-2 font-mono text-sm bg-gray-50 text-gray-600"
        />
        <p class="mt-1 text-sm text-gray-600">Item ID cannot be changed</p>
      </div>

      <!-- Full Statement -->
      <div>
        <label for="fullStatement" class="block text-sm font-medium text-gray-900 mb-2">
          Full Statement <span class="text-red-600">*</span>
        </label>
        <textarea
          id="fullStatement"
          name="fullStatement"
          required
          rows="4"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
        >{{item.fullStatement}}</textarea>
        <p class="mt-1 text-sm text-gray-600">The complete text of the competency or standard</p>
      </div>

      <!-- Human Coding Scheme -->
      <div>
        <label for="humanCodingScheme" class="block text-sm font-medium text-gray-900 mb-2">
          Code/Number
        </label>
        <input
          type="text"
          id="humanCodingScheme"
          name="humanCodingScheme"
          value="{{item.humanCodingScheme}}"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="e.g., CCSS.MATH.1.OA.1"
        />
        <p class="mt-1 text-sm text-gray-600">Optional: The human-readable code or number for this item</p>
      </div>

      <!-- Abbreviated Statement -->
      <div>
        <label for="abbreviatedStatement" class="block text-sm font-medium text-gray-700 mb-2">
          Abbreviated Statement
        </label>
        <input
          type="text"
          id="abbreviatedStatement"
          name="abbreviatedStatement"
          value="{{item.abbreviatedStatement}}"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="A shorter version of the statement..."
        />
        <p class="mt-1 text-sm text-gray-600">Optional: A shortened version of the full statement</p>
      </div>

      <!-- Notes -->
      <div>
        <label for="notes" class="block text-sm font-medium text-gray-700 mb-2">
          Notes
        </label>
        <textarea
          id="notes"
          name="notes"
          rows="3"
          class="w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-plum focus:border-plum text-sm transition-colors"
          placeholder="Additional notes or context..."
        >{{item.notes}}</textarea>
        <p class="mt-1 text-sm text-gray-600">Optional: Additional notes or context about this item</p>
      </div>
    </div>

    <div class="flex items-center gap-2 pt-4 border-t border-gray-200">
      <button
        type="submit"
        class="inline-flex items-center gap-1.5 bg-amber text-white px-4 py-2 rounded-md hover:bg-opacity-90 focus:outline-none focus:ring-2 focus:ring-amber focus:ring-offset-2 text-sm font-medium transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        Update Item
      </button>
      <a
        href="/admin/tenants/{{tenantId}}/frameworks/{{frameworkId}}"
        class="inline-flex items-center gap-1.5 bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300 focus:ring-offset-2 text-sm font-medium transition-colors"
      >
        Cancel
      </a>
    </div>
  </form>
</div>

