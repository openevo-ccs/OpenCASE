  <div class="min-h-screen flex items-center justify-center bg-white py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <h2 class="mt-6 text-center text-3xl font-header font-semibold text-gray-900">
        Sign in to OpenCASE Admin
      </h2>
      <p class="mt-2 text-center text-sm text-gray-600">
        Use your OAuth client credentials
      </p>
    </div>
    <form class="mt-8 space-y-6" method="POST" action="/admin/login">
      {{#if error}}
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md">
          <p class="font-semibold">Error:</p>
          <p>{{error}}</p>
        </div>
      {{/if}}
      
      <div class="rounded-md shadow-sm -space-y-px">
        <div>
          <label for="clientId" class="sr-only">Client ID</label>
          <input
            id="clientId"
            name="clientId"
            type="text"
            required
            class="appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-t-md focus:outline-none focus:ring-plum focus:border-plum focus:z-10 sm:text-sm"
            placeholder="Client ID"
            value="demo-client"
          />
        </div>
        <div>
          <label for="clientSecret" class="sr-only">Client Secret</label>
          <input
            id="clientSecret"
            name="clientSecret"
            type="password"
            required
            class="appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-b-md focus:outline-none focus:ring-plum focus:border-plum focus:z-10 sm:text-sm"
            placeholder="Client Secret"
            value="demo-secret"
          />
        </div>
      </div>

      <div>
        <button
          type="submit"
          class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-amber hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber"
        >
          Sign in
        </button>
      </div>

      <div class="text-sm text-gray-600 text-center">
        <p>Default credentials:</p>
        <p class="font-mono text-xs mt-1">Client ID: demo-client</p>
        <p class="font-mono text-xs">Client Secret: demo-secret</p>
      </div>
    </form>
  </div>
</div>

