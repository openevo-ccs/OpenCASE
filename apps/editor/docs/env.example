## Copy these values into `.env.local` for local development.
## Vite exposes only variables prefixed with `VITE_`.
##
## OpenCASE API base URL
VITE_OPENCASE_BASE_URL=http://localhost:8080
##
## Keycloak realm issuer / authority
VITE_OIDC_AUTHORITY=http://localhost:8081/realms/opencase
##
## This deployment uses client-per-tenant in Keycloak.
## client_id will be `${VITE_OIDC_CLIENT_ID_PREFIX}${tenantId}`.
VITE_OIDC_CLIENT_ID_PREFIX=tenant-

