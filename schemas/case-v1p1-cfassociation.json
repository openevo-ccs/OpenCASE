{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CASE v1.1 CFAssociation Schema",
  "description": "Schema for validating a CFAssociation",
  "$ref": "#/definitions/CFAssociation",
  "definitions": {
    "UUID": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "UUID in format 8-4-4-4-12 hexadecimal characters"
    },
    "LinkGenURI": {
      "type": "object",
      "required": ["title", "identifier", "uri"],
      "properties": {
        "title": {
          "type": "string",
          "description": "A human readable title for the associated object"
        },
        "identifier": {
          "type": "string",
          "description": "An unambiguous, synthetic, globally unique identifier (this may or may not be a UUID) for the associated object"
        },
        "uri": {
          "type": "string",
          "format": "uri",
          "description": "A network-resolvable URI pointing to the authoritative reference for the associated object"
        },
        "targetType": {
          "type": "string",
          "description": "Used to identify the type of the referenced association (new in CASE 1.1). Default is 'CASE'"
        }
      }
    },
    "CFAssociation": {
      "type": "object",
      "required": ["sourcedId", "uri", "associationType", "originNodeURI", "destinationNodeURI", "lastChangeDateTime"],
      "properties": {
        "sourcedId": {
          "$ref": "#/definitions/UUID"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "associationType": {
          "type": "string",
          "description": "The type of association. Uses an extensible enumerated vocabulary. Standard values include: isChildOf, isParentOf, isPartOf, hasPart, isPeerOf, precedes, isRelatedTo, exactMatchOf, replacedBy, replaces, exemplar, isExemplarOf"
        },
        "originNodeURI": {
          "$ref": "#/definitions/LinkGenURI"
        },
        "destinationNodeURI": {
          "$ref": "#/definitions/LinkGenURI"
        },
        "CFDocumentURI": {
          "$ref": "#/definitions/LinkGenURI"
        },
        "sequenceNumber": {
          "type": "integer"
        },
        "lastChangeDateTime": {
          "type": "string",
          "format": "date-time"
        },
        "extensions": {
          "type": "object"
        }
      }
    }
  }
}

