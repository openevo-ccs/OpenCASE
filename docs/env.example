# =============================================================================
# CASE Monorepo - Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed.
# Docker Compose will automatically load .env from the project root.

# =============================================================================
# Traefik Configuration
# =============================================================================

# Main entry point port (browser access)
TRAEFIK_PORT=3000

# Dashboard port (admin UI)
TRAEFIK_DASHBOARD_PORT=8080

# =============================================================================
# Keycloak Configuration
# =============================================================================

# Admin credentials for Keycloak console
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Realm name for CASE authentication
KEYCLOAK_REALM=opencase

# =============================================================================
# OpenCASE Configuration
# =============================================================================

# Directory for framework data persistence
CASE_DATA_DIR=/app/data

# OIDC Configuration (must match Keycloak setup)
# This URL is used for JWT validation - must be accessible from browser
OIDC_ISSUER_URL=http://localhost:3000/realms/opencase

# Client ID prefix for tenant-specific clients
# Full client_id = ${OIDC_CLIENT_ID_PREFIX}${tenantId}
OIDC_CLIENT_ID_PREFIX=tenant-

# Keycloak Admin API (internal Docker network URL)
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# SPA redirect URIs (comma-separated, wildcards allowed)
KEYCLOAK_SPA_REDIRECT_URIS=http://localhost:3000/*
KEYCLOAK_SPA_WEB_ORIGINS=http://localhost:3000

# Bootstrap a system admin user on startup
KEYCLOAK_BOOTSTRAP_SYSTEM_ADMIN=true
KEYCLOAK_SYSTEM_ADMIN_EMAIL=system-admin@local
KEYCLOAK_SYSTEM_ADMIN_PASSWORD=admin

# =============================================================================
# Editor Configuration
# =============================================================================

# OpenCASE API base URL (through Traefik)
VITE_OPENCASE_BASE_URL=http://localhost:3000

# OIDC authority/issuer URL (through Traefik)
VITE_OIDC_AUTHORITY=http://localhost:3000/realms/opencase

# Client ID prefix (must match OIDC_CLIENT_ID_PREFIX)
VITE_OIDC_CLIENT_ID_PREFIX=tenant-
